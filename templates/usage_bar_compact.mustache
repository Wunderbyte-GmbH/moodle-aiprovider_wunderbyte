{{!
    @template aiprovider_wunderbyte/usage_bar_compact

    Compact AI credit indicator, sized to sit inline next to a status pill.

    The context is prepared by amd/src/usage_bar.js (compact variant). See the
    full usage_bar template for the shared context variables; this variant uses
    shortlabel, badgeclass (ok state), unlimitedlabel (unlimited) and
    message/detail (unavailable).

    Example context (json):
    {
        "isok": true,
        "badgeclass": "badge-success",
        "shortlabel": "$1.17 left",
        "remaininglabel": "$1.17 of $2.00 remaining",
        "spentlabel": "$0.83 used"
    }
}}
<span class="aiprovider-wunderbyte-usage-compact d-inline-flex align-items-center" data-region="wb-usage">
    {{!
        Trial/usage (compact): a percentage badge (colour by usage) with the reset/
        expiry in the tooltip. Deliberately NO money amounts.
    }}
    {{#isok}}
        <span class="badge {{badgeclass}}" title="{{#resetlabel}}{{resetlabel}}{{/resetlabel}}{{^resetlabel}}{{expireslabel}}{{/resetlabel}}">{{shortlabel}}</span>
    {{/isok}}
    {{#isunlimited}}
        <span class="badge badge-info" title="{{unlimiteddetail}}">{{unlimitedlabel}}</span>
    {{/isunlimited}}
    {{#ismessage}}
        <span class="small text-muted" title="{{detail}}">{{message}}</span>
    {{/ismessage}}
</span>
