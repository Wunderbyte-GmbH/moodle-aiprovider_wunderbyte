{{!
    @template aiprovider_wunderbyte/usage_bar

    AI credit usage widget.

    The context is fully prepared by amd/src/usage_bar.js (all labels already
    localised and formatted), so this template stays purely presentational and
    can be rendered identically wherever the bar is shown.

    Classes required for JS:
    * none

    Context variables required for this template:
    * heading string Widget heading.
    * state string One of: ok, unlimited, unavailable, unconfigured.
    * percent number Percentage of budget used (ok state only).
    * barclass string Bootstrap background class for the bar (ok state only).
    * remaininglabel string e.g. "$1.17 of $2.00 remaining" (ok state only).
    * spentlabel string e.g. "$0.83 used" (ok state only).
    * resetlabel string Optional reset-date label.
    * expireslabel string Optional expiry-date label.
    * unlimitedlabel string Headline for the unlimited state.
    * unlimiteddetail string Detail for the unlimited state.
    * message string Message for unavailable/unconfigured states.

    Example context (json):
    {
        "heading": "AI credit",
        "state": "ok",
        "percent": 42,
        "barclass": "bg-success",
        "remaininglabel": "$1.17 of $2.00 remaining",
        "spentlabel": "$0.83 used",
        "resetlabel": "Resets 29 Jun 2026",
        "expireslabel": ""
    }
}}
<div class="aiprovider-wunderbyte-usage" data-region="wb-usage">
    <div class="d-flex justify-content-between align-items-baseline mb-1">
        <span class="font-weight-bold">{{heading}}</span>
        {{#remaininglabel}}<span class="small text-muted">{{remaininglabel}}</span>{{/remaininglabel}}
        {{#unlimitedlabel}}<span class="badge badge-info">{{unlimitedlabel}}</span>{{/unlimitedlabel}}
    </div>

    {{#isok}}
        <div class="progress" style="height: 0.75rem;" role="progressbar"
            aria-valuenow="{{percent}}" aria-valuemin="0" aria-valuemax="100" aria-label="{{heading}}">
            <div class="progress-bar {{barclass}}" style="width: {{percent}}%;"></div>
        </div>
        <div class="d-flex justify-content-between small text-muted mt-1">
            <span>{{spentlabel}}</span>
            <span>
                {{#resetlabel}}{{resetlabel}}{{/resetlabel}}
                {{#expireslabel}}{{^resetlabel}}{{expireslabel}}{{/resetlabel}}{{/expireslabel}}
            </span>
        </div>
    {{/isok}}

    {{#isunlimited}}
        <div class="small text-muted">{{unlimiteddetail}}</div>
    {{/isunlimited}}

    {{#ismessage}}
        <div class="small text-muted font-italic">{{message}}</div>
        {{#detail}}<div class="small text-muted">{{detail}}</div>{{/detail}}
    {{/ismessage}}
</div>
